		<style id="wp-custom-css">
			/* ----------------- E-LEVA ----------------- */

/* --------- GLOBAL --------- */
.elementor-widget-uael-posts .uael-post__content-wrap {
	display: flex;
	flex-direction: column;
  align-items: flex-start;
}
.elementor-widget-uael-posts .uael-post__content-wrap .uael-post__meta-data {
	order: 1;
}
.elementor-widget-uael-posts .uael-post__content-wrap .uael-post__title {
	order: 2;
}
.elementor-widget-uael-posts .uael-post__content-wrap .uael-post__excerpt {
	order: 3;
}
.elementor-widget-uael-posts .uael-post__content-wrap .uael-post__read-more {
	order: 4;
}
.elementor-widget-uael-posts .uael-post__content-wrap .elementor-button-icon svg {
	fill: var(--ast-global-color-1);
}
.uael-video-gallery-wrap ul.slick-dots li button, .uael-video-gallery-wrap .slick-next, .uael-video-gallery-wrap .slick-prev, .uael-img-gallery-wrap ul.slick-dots li button, .uael-img-gallery-wrap .slick-next, .uael-img-gallery-wrap .slick-prev {
	box-shadow: none;
}
.white-dots .uael-img-gallery-wrap li.slick-active button:before {
	color: #fff!important;
	opacity: unset!important
}
.white-dots .uael-img-gallery-wrap .slick-dots button:before {
	color: #fff!important;
	opacity: .5!important;
}
.uael-video-gallery-wrap li.slick-active button:before, .uael-img-gallery-wrap li.slick-active button:before {
	color: var(--ast-global-color-1)!important;
	transition: .5s all;
}
.uael-video-gallery-wrap ul.slick-dots {
	width: fit-content;
	padding-left: 15px;
}
.uael-video-gallery-wrap .slick-track {
	padding-bottom: 50px;
}
.uael-video-gallery-wrap .slick-prev, .uael-video-gallery-wrap .slick-next, .uael-video-gallery-wrap .slick-prev:hover, .uael-video-gallery-wrap .slick-next:hover, .uael-video-gallery-wrap .slick-prev:focus, .uael-video-gallery-wrap .slick-next:focus {
	bottom: -86px;
	top: unset;
	border: 1px solid #000;
}
.uael-img-gallery-wrap ul.slick-dots {
	bottom: 25px;
}
.uael-img-gallery-wrap {
	margin-bottom: 0!important;
}
.uael-video-gallery-wrap .slick-next {
	right: 15px;
}
.uael-video-gallery-wrap .slick-prev {
	right: 80px;
	left: unset;
}
.uael-video-gallery-wrap .fa-angle-left:before, .uael-posts .slick-prev .fa-angle-left:before {
	content: url("/wp-content/uploads/2025/05/arrow-left_black.svg");
}
.uael-video-gallery-wrap .fa-angle-right:before, .uael-posts .slick-next .fa-angle-right:before {
	content: url("/wp-content/uploads/2025/05/arrow-right_black.svg");
}
.uael-img-gallery-wrap .slick-prev, .uael-img-gallery-wrap .slick-next {
	border: 1px solid #fff;
	border-radius: 50%;
	width: 48px;
	height: 48px;
}
.uael-posts .slick-prev .fa-angle-left, .uael-posts .slick-next .fa-angle-right {
	border: 1px solid #000;
	border-radius: 50%;
	width: 48px!important;
	height: 48px!important;
	line-height: 58px!important;
}
.uael-img-gallery-wrap .slick-prev:before {
	content: url("/wp-content/uploads/2025/05/arrow-left_white.svg");
	opacity: 1;
	line-height: 44px;
}
.uael-img-gallery-wrap .slick-next:before {
	content: url("/wp-content/uploads/2025/05/arrow-right_white.svg");
	opacity: 1;
	line-height: 44px;
}
.uael-video-gallery-wrap .slick-prev i, .uael-video-gallery-wrap .slick-next i, .uael-video-gallery-wrap .slick-prev i:hover, .uael-video-gallery-wrap .slick-next i:hover, .uael-video-gallery-wrap .slick-prev i:focus, .uael-video-gallery-wrap .slick-next i:focus {
	width: 48px;
	height: 48px;
	line-height: 58px;
}
.elementor-element.download-pdf:hover .elementor-icon-box-title {
	color: var(--ast-global-color-1);
	transition: .5s;
}
.elementor-element.download-pdf:hover .elementor-button {
	color: var(--ast-global-color-1);
	border-color: var(--ast-global-color-1);
}
.btn-arrow-white .elementor-button:hover svg path {
	fill: var(--ast-global-color-1);
}
.btn-arrow-red .elementor-button:hover svg path {
	fill: #fff;
}
br.no-mobile {
	display: none;
}
.text-colored {
	color: var(--ast-global-color-1);
}
/* ----- CF7 ----- */
.cf-container {
	display: -ms-flexbox;
	display: flex;
	-ms-flex-wrap: wrap;
	flex-wrap: wrap;
	margin-right: -5px;
	margin-left: -5px;
}
.cf-col-1, .cf-col-2, .cf-col-3, .cf-col-4, .cf-col-5, .cf-col-6, .cf-col-7, .cf-col-8, .cf-col-9, .cf-col-10, .cf-col-11, .cf-col-12 {
	position: relative;
	width: 100%;
	min-height: 1px;
	padding-right: 8px;
	padding-left: 8px;
}
input, textarea, .wpcf7 input[type=checkbox], .wpcf7 input[type=radio] {
	border-radius: 0!important;
}
.wpcf7 label {
	font-size: 16px;
	font-weight: 400;
}
.wpcf7 .cf-col-6 .wpcf7-form-control-wrap {
	margin-top: 10px;
	margin-bottom: 25px;
}
.wpcf7 .cf-col-12 .wpcf7-form-control-wrap {
	margin: 10px 0;
}
.wpcf7-list-item {
	margin-left: 8px;
	margin-bottom: 10px;
}
.wpcf7 .wpcf7-list-item-label {
	font-size: 14px;
}
.wpcf7 input[type=checkbox], .wpcf7 input[type=radio] {
	width: 1em;
	min-width: 1em;
}
.wpcf7-submit {
	background-color: #000!important;
	color: #fff!important;
	text-transform: none!important;
	border: 1px solid #000!important;
	width: 100%;
	transition: .5s all;
}
.wpcf7-submit:hover {
	background-color: transparent!important;
	color: #000!important;
}
.wpcf7 .form-submit {
	margin: 0 3px;
}
.form-newsletter .wpcf7-submit {
	width: auto;
}
/* ----- /CF7 ----- */
/* --------- /GLOBAL --------- */

/* --------- HEADER --------- */
#ast-desktop-header .main-header-menu .sub-menu {
	width: 320px;
}
#ast-desktop-header .main-header-menu .sub-menu .menu-link {
	padding: .5em 2em;
}
#ast-desktop-header .main-header-menu .sub-menu .menu-item:first-child {
	padding-top: 1em;
}
#ast-desktop-header .main-header-menu .sub-menu .menu-item:last-child {
	padding-bottom: 1em;
}
.main-header-bar.ast-sticky-active {
	box-shadow: none;
}
.ast-builder-menu-mobile .main-navigation .menu-item.menu-item-has-children > .ast-menu-toggle {
	right: 28px;
	box-shadow: none;
}
/* --------- /HEADER --------- */

/* --------- FOOTER --------- */
footer .site-below-footer-wrap {
	max-width: 1312px;
	margin: auto;
}
/* --------- /FOOTER --------- */

/* --------- ARCHIVE BLOG --------- */
.elementor-widget-uael-posts .uael-grid-pagination a.next.page-numbers:after {
	content: url("/wp-content/uploads/2025/05/arrow-right_pagination.svg");
	margin-left: -10px;
	background: #fff;
	padding: 5px 10px;
	position: relative;
	z-index: 1;
}
.elementor-widget-uael-posts .uael-grid-pagination a.prev.page-numbers:before {
	content: url("/wp-content/uploads/2025/05/arrow-left_pagination.svg");
	margin-right: -10px;
	background: #fff;
	padding: 5px 10px;
	position: relative;
	z-index: 1;
}
.uael-grid-pagination a.next.page-numbers:hover, 
.uael-grid-pagination a.prev.page-numbers:hover {
	color: unset!important;
	background-color: unset!important;
}
.product-menu nav.menu-is-active {
	left: -25px!important;
}
/* --------- /ARCHIVE BLOG --------- */

/* --------- HOME PAGE --------- */
.slider-1-hp .premium-carousel-wrapper a.carousel-arrow, .slider-2-hp .premium-carousel-wrapper a.carousel-arrow {
	top: unset;
	z-index: 1;
}
.slider-1-hp .premium-carousel-wrapper a.carousel-arrow {
	bottom: 40px;
}
.slider-1-hp .premium-carousel-dots-below ul.slick-dots, .slider-1-hp .premium-woocommerce ul.slick-dots {
	position: absolute;
	bottom: 52px;
	left: 50%;
	transform: translateX(-50%);
}
.slider-2-hp .premium-carousel-wrapper a.carousel-arrow {
	bottom: 15px;
}
.slider-2-hp .premium-carousel-dots-below ul.slick-dots, .slider-2-hp .premium-woocommerce ul.slick-dots {
	position: absolute;
	bottom: 52px;
}
.slider-2-hp .premium-carousel-dots-below ul.slick-dots, .slider-2-hp .premium-woocommerce ul.slick-dots {
	left: 18px;
	margin-left: unset;
}
.slider-2-hp .premium-carousel-wrapper .carousel-arrow.carousel-prev {
	left: unset!important;
	right: 90px;
}
.uael-posts .slick-arrow {
	top: -60px!important;
}
.uael-post__arrow-inside .uael-post-grid .slick-next {
	right: 15px;
}
.uael-post__arrow-inside .uael-post-grid .slick-prev {
	right: 80px;
	left: unset;
}
/* --------- /HOME PAGE --------- */

/* --------- BLOG --------- */
.elementor-widget-premium-addon-blog .premium-blog-excerpt-link {
	display: flex;
	align-items: center;
	gap: 15px;
}
.elementor-widget-premium-addon-blog .premium-blog-excerpt-link .fa-chevron-right {
	display: flex;
}
.elementor-widget-premium-addon-blog .premium-blog-excerpt-link .fa-chevron-right:before {
	font-size: 11px;
}
.elementor-widget-premium-addon-blog .premium-blog-inner-container .premium-blog-entry-title {
	order: 2;
	margin-left: 1px;
}
.elementor-widget-premium-addon-blog .premium-blog-inner-container .premium-blog-entry-meta {
	order: 1;
}
.elementor-widget-premium-addon-blog .premium-blog-inner-container .premium-blog-entry-meta .fa-calendar-alt {
	display: none;
}
.elementor-widget-premium-addon-blog .premium-blog-content-inner-wrapper {
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	height: -webkit-fill-available;
	max-height: 146px;
}
.elementor-widget-premium-addon-blog .next.page-numbers, .elementor-widget-premium-addon-blog .prev.page-numbers {
	font-size: 0!important;
}
.elementor-widget-premium-addon-blog .next.page-numbers::before {
	content: "Successivo";
	font-size: 16px;
	margin-right: 10px;
}
.elementor-widget-premium-addon-blog .prev.page-numbers::after {
	content: "Precedente";
	font-size: 16px;
	margin-left: 10px;
}
.elementor-widget-premium-addon-blog .fa-arrow-right, .elementor-widget-premium-addon-blog .fa-arrow-left  {
	font-size: 14px!important;
}
/* --------- /BLOG --------- */

/* --------- SINGLE POST --------- */
.single-post .ast-container--narrow {
	max-width: 1370px;
}
.single-post .ast-single-entry-banner {
	border-bottom: 1px solid var(--ast-global-color-1);
}
.single-post .ast-article-single {
	background-color: unset!important;
}
